DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (Defaults to sqlite:///db.sqlite3 if not defined)
DATABASE_URL=sqlite:///db.sqlite3

# For production PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/portfolio

# CORS and CSRF Configuration (comma-separated URLs)
# Set these to your hosted frontend URL (e.g. https://yourportfolio.vercel.app)
# Alternatively, set CORS_ALLOW_ALL_ORIGINS=True to allow all origins (recommended for public portfolio APIs)
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:3001
